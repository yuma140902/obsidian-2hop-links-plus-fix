{
  "name": "2hop-links-plus-fix",
  "version": "0.37.1",
  "description": "Related links up to 2 hops away are displayed in a card format, allowing for easy browsing through connections between notes. Each card contains a preview of the corresponding note.",
  "main": "main.js",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "tsc -noEmit -skipLibCheck && biome check",
    "format": "biome format --write ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@babel/preset-react": "7.28.5",
    "@biomejs/biome": "2.4.15",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "builtin-modules": "5.2.0",
    "esbuild": "0.28.0",
    "obsidian": "1.12.3",
    "typescript": "5.9.3"
  }
}
